<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="TextAppearance.GenStream" parent="TextAppearance.AppCompat" />

    <style name="TextAppearance.GenStream.Title">
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textSize">16sp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="TextAppearance.GenStream.TitleButton">
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textSize">16sp</item>
    </style>


    <style name="TextAppearance.GenStream.Body">
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textSize">14sp</item>
    </style>

    <style name="TextAppearance.GenStream.BodyBold">
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textSize">14sp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="TextAppearance.GenStream.SecondaryBody">
        <item name="android:textColor">@color/text_secondary</item>
        <item name="android:textSize">14sp</item>
    </style>

</resources>
