<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_color">

    <!-- Container for artwork to clip it during scale animation -->
    <FrameLayout
        android:id="@+id/flGameArtwork"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintWidth_percent="0.65">

        <ImageView
            android:id="@+id/ivGameArtwork"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="centerCrop"
            android:src="@drawable/image_1" />
    </FrameLayout>

    <!-- Blending Gradient: Horizontal black-to-transparent overlay -->
    <View
        android:id="@+id/vBlendGradient"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:background="@drawable/bg_gradient_horizontal_black"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="@id/flGameArtwork"
        app:layout_constraintStart_toStartOf="@id/flGameArtwork"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Top Bar (matches homefragment structure) -->
    <LinearLayout
        android:id="@+id/topBar"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="20dp"
        android:translationZ="4dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:id="@+id/btnBack"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:padding="4dp"
            android:src="@drawable/ic_back"
            app:tint="@color/white"
            android:clickable="true"
            android:focusable="true"
            android:background="?attr/selectableItemBackgroundBorderless" />

        <Space
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1" />

        <include
            android:id="@+id/statusIcons"
            layout="@layout/layout_status_icons" />

    </LinearLayout>

    <!-- Main Game Details (Left Section) -->
    <LinearLayout
        android:id="@+id/llGameDetails"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="54dp"
        android:layout_marginEnd="54dp"
        android:orientation="vertical"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/topBar"
        app:layout_constraintVertical_bias="0.4">

        <!-- Game Title -->
        <TextView
            android:id="@+id/tvGameTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Call Duty"
            android:textColor="@color/white"
            android:textSize="32sp"
            android:textStyle="bold" />

        <!-- Subtitle/Description -->
        <TextView
            android:id="@+id/tvGameDesc"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Unveil the Hidden Truth in Black Myth: Call Duty become the legend"
            android:textColor="@color/text_primary"
            android:textSize="14sp"/>

        <!-- Platform Icons -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@drawable/ic_windows"
                app:tint="@color/white" />

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:layout_marginStart="14dp"
                android:src="@drawable/ic_steam"/>

        </LinearLayout>

        <!-- Play now & More Buttons Row -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="52dp"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <!-- Play Now Button -->
            <TextView
                android:id="@+id/btnPlayNow"
                android:layout_width="235dp"
                android:layout_height="44dp"
                android:background="@drawable/bg_button_play_now"
                android:gravity="center"
                android:text="Play now"
                android:textColor="@color/black"
                android:textSize="16sp"
                android:textStyle="bold"
                android:clickable="true"
                android:focusable="true" />

            <!-- More Button (...) -->
            <TextView
                android:id="@+id/btnMore"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:layout_marginStart="6dp"
                android:background="@drawable/bg_button_more"
                android:gravity="center"
                android:text="•••"
                android:textColor="@color/white"
                android:textSize="14sp"
                android:textStyle="bold"
                android:clickable="true"
                android:focusable="true" />

        </LinearLayout>

    </LinearLayout>

    <!-- Check Compatibility Button -->
    <TextView
        android:id="@+id/btnCheckCompatibility"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:layout_marginStart="242dp"
        android:background="@drawable/bg_badge_compatibility"
        android:paddingHorizontal="16dp"
        android:paddingVertical="10dp"
        android:text="Check Compatibility"
        android:textColor="@color/white"
        android:textSize="14sp"
        android:clickable="true"
        android:focusable="true"
        app:layout_constraintTop_toBottomOf="@id/llGameDetails"
        app:layout_constraintStart_toStartOf="@id/llGameDetails"/>

    <!-- Footer (matches homefragment footer structure) -->
    <ImageView
        android:id="@+id/footer"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginEnd="20dp"
        android:layout_marginBottom="16dp"
        android:src="@drawable/ic_footer_group"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
