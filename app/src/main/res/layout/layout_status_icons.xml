<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:gravity="center_vertical"
    android:orientation="horizontal">

    <ImageView
        android:id="@+id/ivStatusSearch"
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:layout_marginEnd="8dp"
        android:padding="8dp"
        android:clickable="true"
        android:focusable="true"
        android:nextFocusUp="@id/ivStatusSearch"
        android:nextFocusRight="@id/ivStatusSearch"
        android:nextFocusLeft="@id/tabFindGame"
        android:background="@drawable/bg_view_selector"
        android:src="@drawable/ic_search"
        app:tint="@color/white" />

    <ImageView
        android:id="@+id/ivStatusGamepad"
        android:layout_width="16dp"
        android:layout_height="16dp"
        android:layout_marginEnd="16dp"
        android:focusable="false"
        android:src="@drawable/ic_controller_game"
        app:tint="@color/white" />

    <ImageView
        android:id="@+id/ivStatusWifi"
        android:layout_width="16dp"
        android:layout_height="16dp"
        android:layout_marginEnd="16dp"
        android:focusable="false"
        android:src="@drawable/ic_wifi"
        app:tint="@color/white" />

    <ImageView
        android:id="@+id/ivStatusBattery"
        android:layout_width="18dp"
        android:layout_height="18dp"
        android:layout_marginEnd="16dp"
        android:focusable="false"
        android:src="@drawable/ic_battery"
        app:tint="@color/white" />

    <TextView
        android:id="@+id/tvStatusTime"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="10:16"
        android:textColor="@color/white"
        android:textSize="14sp"
        android:focusable="false"
        android:textStyle="bold" />

</LinearLayout>
