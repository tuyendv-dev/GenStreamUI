<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Gradient border layer -->
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:startColor="#515558"
                android:endColor="#E4E5E5"
                android:angle="0" />
            <corners android:radius="12dp" />
        </shape>
    </item>

    <!-- Inner background layer (creates the 1dp border effect) -->
    <item
        android:bottom="1dp"
        android:left="1dp"
        android:right="1dp"
        android:top="1dp">
        <shape android:shape="rectangle">
            <!-- Match the activity background color so the inside looks transparent -->
            <solid android:color="#0A0000" />
            <corners android:radius="11dp" />
        </shape>
    </item>
</layer-list>
